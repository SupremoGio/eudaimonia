# ── Base de datos ─────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ── Flask ─────────────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO

# ── Módulo Finanzas ───────────────────────────────────────────────────────────
# Contraseña para desbloquear el módulo de finanzas.
# Usa werkzeug para verificación segura (PBKDF2+SHA256+salt).
FINANZAS_PASSWORD=CAMBIA_ESTO

# ── Anthropic / IA ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

