# ══════════════════════════════════════════════════════════════════════════════
#  EUDAIMONIA OS v3 — Variables de Entorno
#  Copia este archivo como .env para desarrollo local.
#  En Railway: configura cada variable en el panel Variables del proyecto.
#  NUNCA subas .env al repositorio — solo este .env.example.
# ══════════════════════════════════════════════════════════════════════════════

# ── Turso (base de datos en la nube) ─────────────────────────────────────────
# Obtén estos valores en: https://app.turso.tech → tu base de datos → Connect
TURSO_DATABASE_URL=libsql://nombre-tu-db-usuario.turso.io
TURSO_AUTH_TOKEN=tu-token-aqui

# ── Flask ─────────────────────────────────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza-con-una-clave-secreta-larga

# ── Base de datos local (opcional) ────────────────────────────────────────────
# Solo necesario si montas un Railway Volume en /data.
# Si no se define, usa gio_v3/pipeline.db en desarrollo local.
# DATABASE_PATH=/data/pipeline.db
